<UserControl x:Class="TubeStar.MainPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:TubeStar"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Custom.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="LayoutRoot" Background="#080808">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- COLUMN 0: LEFT SIDEBAR NAVIGATION -->
        <Border Grid.Column="0" Background="#121212" BorderBrush="#222222" BorderThickness="0,0,1,0">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Logo/Header -->
                    <RowDefinition Height="*" />    <!-- Nav Menu -->
                    <RowDefinition Height="Auto" /> <!-- System Controls -->
                    <RowDefinition Height="Auto" /> <!-- Profile Card -->
                </Grid.RowDefinitions>

                <!-- Header Logo -->
                <StackPanel Grid.Row="0" Margin="0,0,0,25">
                    <TextBlock Text="TUBE STAR" FontSize="26" FontWeight="Black" Foreground="#FF2222" HorizontalAlignment="Center"/>
                    <TextBlock Text="GAMER DASHBOARD" FontSize="10" Foreground="#666666" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Grid.Row="1" Orientation="Vertical">
                    <ToggleButton x:Name="btnDailyPlanner" IsChecked="True" Height="42" Margin="0,4" HorizontalContentAlignment="Left" Padding="12,0" Click="btnDailyPlanner_Click">
                        <ToggleButton.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/Home_icon.png" Width="16" Height="16" Margin="0,0,10,0" />
                                <TextBlock x:Name="txtDailyPlanner" Text="Agenda Diária" VerticalAlignment="Center" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                        </ToggleButton.Content>
                    </ToggleButton>

                    <ToggleButton x:Name="btnVideoPlanner" Height="42" Margin="0,4" HorizontalContentAlignment="Left" Padding="12,0" Click="btnVideoPlanner_Click">
                        <ToggleButton.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/Video_icon.png" Width="16" Height="16" Margin="0,0,10,0" />
                                <TextBlock x:Name="txtVideoPlanner" Text="Meus Vídeos" VerticalAlignment="Center" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                        </ToggleButton.Content>
                    </ToggleButton>

                    <ToggleButton x:Name="btnOnlineStore" Height="42" Margin="0,4" HorizontalContentAlignment="Left" Padding="12,0" Click="btnOnlineStore_Click">
                        <ToggleButton.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/Cart_icon.png" Width="16" Height="16" Margin="0,0,10,0" />
                                <TextBlock x:Name="txtOnlineStore" Text="Loja de Equipamentos" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" />
                            </StackPanel>
                        </ToggleButton.Content>
                    </ToggleButton>

                    <ToggleButton x:Name="btnRivals" Height="42" Margin="0,4" HorizontalContentAlignment="Left" Padding="12,0" Click="btnRivals_Click">
                        <ToggleButton.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/Rivals_icon.png" Width="16" Height="16" Margin="0,0,10,0" />
                                <TextBlock x:Name="txtRivals" Text="Canais Rivais" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" />
                            </StackPanel>
                        </ToggleButton.Content>
                    </ToggleButton>
                </StackPanel>

                <!-- System Controls (Save/Help/Exit) -->
                <Border Grid.Row="2" Background="#181818" CornerRadius="6" Padding="8" Margin="0,0,0,15" BorderBrush="#222222" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" x:Name="imgSave" Source="Resources/Disk.png" Height="24" Width="24" MouseLeftButtonDown="Save_MouseLeftButtonDown" Style="{StaticResource TriggerClickStyle}" MouseEnter="imgSave_MouseEnter" MouseLeave="imgSave_MouseLeave" Cursor="Hand"/>
                        <Image Grid.Column="1" x:Name="gridHelp" Source="Resources/Help.png" Height="24" Width="24" MouseLeftButtonDown="Tutorial_MouseLeftButtonDown" Style="{StaticResource TriggerClickStyle}" MouseEnter="gridHelp_MouseEnter" MouseLeave="gridHelp_MouseLeave" Cursor="Hand"/>
                        <Image Grid.Column="2" x:Name="gridExit" Source="Resources/Exit.png" Height="24" Width="24" MouseLeftButtonDown="Exit_MouseLeftButtonDown" Style="{StaticResource TriggerClickStyle}" MouseEnter="gridExit_MouseEnter" MouseLeave="gridExit_MouseLeave" Cursor="Hand"/>
                    </Grid>
                </Border>

                <!-- Youtuber Character Profile Card -->
                <Border Grid.Row="3" Background="#1E1E1E" CornerRadius="10" BorderBrush="#333333" BorderThickness="1" Padding="10" Cursor="Hand" MouseLeftButtonDown="ProfileCard_Click" ToolTip="Clique para customizar seu visual!">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Mini circular glowing avatar representing neon hair color -->
                        <Border Grid.Column="0" x:Name="profileAvatarGlow" Width="50" Height="50" CornerRadius="25" BorderThickness="2" BorderBrush="#00FFFF" Margin="0,0,10,0">
                            <Border.Effect>
                                <DropShadowEffect x:Name="profileAvatarGlowEffect" BlurRadius="8" ShadowDepth="0" Color="#00FFFF" Opacity="0.7"/>
                            </Border.Effect>
                            <Border CornerRadius="25" Background="#282828" ClipToBounds="True">
                                <Viewbox Width="44" Height="44" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas x:Name="miniAvatarCanvas" Width="180" Height="180">
                                        <!-- Camada de Tatuagens (Fundo) -->
                                        <Path x:Name="miniTattooGeek" Data="M 30,130 L 50,110 L 60,120 M 120,120 L 130,110 L 150,130" Stroke="#44FF2222" StrokeThickness="3" Visibility="Collapsed" />
                                        <Path x:Name="miniTattooTribal" Data="M 35,125 Q 50,115 65,128 M 115,128 Q 130,115 145,125" Stroke="#4400FFFF" StrokeThickness="3" StrokeDashArray="2,2" Visibility="Collapsed" />
                                        <Path x:Name="miniTattooGamer" Data="M 40,135 L 60,130 L 70,145 M 110,145 L 120,130 L 140,135" Stroke="#44FFFF00" StrokeThickness="4" Visibility="Collapsed" />

                                        <!-- Corpo (Vestuário) -->
                                        <Path x:Name="miniBodyBase" Data="M 30,160 C 30,125 60,105 90,105 C 120,105 150,125 150,160 Z" Fill="#2D2D2D" Stroke="#3D3D3D" StrokeThickness="2" />
                                        
                                        <!-- Linhas e preenchimentos extras do Outfit -->
                                        <Path x:Name="miniClothingTshirt" Data="M 65,105 Q 90,125 115,105" Stroke="#E74C3C" StrokeThickness="4" Visibility="Visible" />
                                        <Path x:Name="miniClothingHoodie" Data="M 60,103 Q 90,120 120,103 L 110,128 L 70,128 Z" Fill="#FF2222" Stroke="#880000" StrokeThickness="1" Visibility="Collapsed" />
                                        <Path x:Name="miniClothingJacket" Data="M 55,105 L 75,135 M 125,105 L 105,135" Stroke="#D4AC0D" StrokeThickness="3" Visibility="Collapsed" />
                                        <Path x:Name="miniClothingSuit" Data="M 60,105 L 90,135 L 120,105 M 90,135 L 90,160" Stroke="#FFFFFF" StrokeThickness="2" Visibility="Collapsed" />

                                        <!-- Rosto -->
                                        <Ellipse x:Name="miniHeadBase" Width="70" Height="80" Canvas.Left="55" Canvas.Top="35" Fill="#FFD1A9" Stroke="#E0A375" StrokeThickness="1"/>

                                        <!-- Olhos -->
                                        <Ellipse Width="6" Height="6" Canvas.Left="75" Canvas.Top="60" Fill="#1E1E1E" />
                                        <Ellipse Width="6" Height="6" Canvas.Left="99" Canvas.Top="60" Fill="#1E1E1E" />
                                        <Path Data="M 82,78 Q 90,86 98,78" Stroke="#1E1E1E" StrokeThickness="2" Fill="Transparent" />

                                        <!-- Acessório Óculos -->
                                        <Canvas x:Name="miniAccGlassesCanvas" Visibility="Collapsed" Canvas.Left="55" Canvas.Top="35">
                                            <Path Data="M 12,23 L 30,23 M 40,23 L 58,23" Stroke="#00FFFF" StrokeThickness="2" />
                                            <Ellipse Width="16" Height="16" Canvas.Left="14" Canvas.Top="15" Stroke="#00FFFF" StrokeThickness="2" Fill="#3300FFFF" />
                                            <Ellipse Width="16" Height="16" Canvas.Left="40" Canvas.Top="15" Stroke="#00FFFF" StrokeThickness="2" Fill="#3300FFFF" />
                                        </Canvas>

                                        <!-- Cabelos -->
                                        <Path x:Name="miniHairSpiky" Data="M 55,45 L 60,25 L 70,35 L 80,20 L 90,35 L 100,20 L 110,35 L 120,25 L 125,45 L 120,53 L 60,53 Z" Fill="#00FFFF" Stroke="#FFFFFF" StrokeThickness="0.5" Visibility="Visible" />
                                        <Path x:Name="miniHairMohawk" Data="M 85,35 L 90,5 L 95,35 Z M 88,35 L 90,10 L 92,35 Z" Fill="#00FFFF" Stroke="#FFFFFF" StrokeThickness="0.5" Visibility="Collapsed" />
                                        <Path x:Name="miniHairPompadour" Data="M 55,45 C 55,15 125,15 125,45 Z" Fill="#00FFFF" Stroke="#FFFFFF" StrokeThickness="0.5" Visibility="Collapsed" />
                                        <Path x:Name="miniHairGamer" Data="M 55,45 Q 90,15 125,45 L 115,58 Q 90,45 65,58 Z" Fill="#00FFFF" Stroke="#FFFFFF" StrokeThickness="0.5" Visibility="Collapsed" />
                                        <Path x:Name="miniHairWavy" Data="M 55,45 C 40,55 45,95 45,95 L 60,85 Q 55,60 65,55 M 125,45 C 140,55 135,95 135,95 L 120,85 Q 125,60 115,55" Stroke="#00FFFF" StrokeThickness="5" Fill="Transparent" Visibility="Collapsed" />

                                        <!-- Acessório Headphones -->
                                        <Canvas x:Name="miniAccHeadphonesCanvas" Visibility="Collapsed" Canvas.Left="55" Canvas.Top="35">
                                            <Path Data="M 5,25 A 30,30 0 0,1 65,25" Stroke="#FF2222" StrokeThickness="4" Fill="Transparent" />
                                            <Ellipse Width="12" Height="24" Canvas.Left="-2" Canvas.Top="18" Fill="#FF2222" Stroke="#FFFFFF" StrokeThickness="1"/>
                                            <Ellipse Width="6" Height="14" Canvas.Left="1" Canvas.Top="23" Fill="#1E1E1E" />
                                            <Ellipse Width="12" Height="24" Canvas.Left="60" Canvas.Top="18" Fill="#FF2222" Stroke="#FFFFFF" StrokeThickness="1"/>
                                            <Ellipse Width="6" Height="14" Canvas.Left="63" Canvas.Top="23" Fill="#1E1E1E" />
                                        </Canvas>

                                        <!-- Acessório Boné -->
                                        <Canvas x:Name="miniAccCapCanvas" Visibility="Collapsed" Canvas.Left="55" Canvas.Top="35">
                                            <Path Data="M 6,18 C 6,-2 64,-2 64,18 Z" Fill="#FFCC00" Stroke="#B38F00" StrokeThickness="1" />
                                            <Path Data="M 50,18 L 78,13 L 64,25 Z" Fill="#E5E5E5" Stroke="#B3B3B3" StrokeThickness="1" />
                                        </Canvas>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="txtProfileName" Text="Gamer Pro" FontSize="13" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="txtMoney" Text="$950.00" FontSize="12" FontWeight="Bold" Foreground="#00FF00" Margin="0,2,0,0"/>
                            <TextBlock x:Name="txtCareerDays" Text="Dia 1" FontSize="10" Foreground="#888888"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- COLUMN 1: CENTER ACTIVE WORKSPACE -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />    <!-- Content Panel -->
                <RowDefinition Height="Auto" /> <!-- Next Day Action Bar -->
            </Grid.RowDefinitions>

            <!-- Dashboard Content Container (Premium Card View) -->
            <Border Grid.Row="0" Background="#121212" CornerRadius="12" BorderBrush="#2E2E2E" BorderThickness="1" Padding="15">
                <Grid>
                    <!-- Active Views -->
                    <local:DailyPlanner x:Name="dailyPlanner" />
                    <local:VideoManagerControl x:Name="videoManager" Visibility="Collapsed" />
                    <local:OnlineStoreControl x:Name="onlineStore" Visibility="Collapsed" />
                    <local:RivalControl x:Name="rivalViewer" Visibility="Collapsed" />
                </Grid>
            </Border>

            <!-- Next Day Action Bar at the Bottom -->
            <Border Grid.Row="1" Background="#121212" CornerRadius="10" BorderBrush="#2E2E2E" BorderThickness="1" Padding="12" Margin="0,15,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtNewDay" Text="Iniciar Dia 2!" FontSize="15" FontWeight="Bold" Foreground="#FF2222" />
                        <TextBlock Text="Planeje suas tarefas diárias na agenda antes de passar o dia." FontSize="11" Foreground="#888888" Margin="0,2,0,0" />
                    </StackPanel>

                    <!-- Next Day glowing button -->
                    <Button Grid.Column="1" x:Name="btnNewDay" Height="45" Width="220" FontSize="16" Click="btnNewDay_Click" Style="{StaticResource TriggerClickStyle}" Background="#FF2222" Foreground="White" BorderThickness="0">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/Play_icon.png" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="PASSAR O DIA" FontWeight="Bold" VerticalAlignment="Center"/>
                                <ProgressBar x:Name="progress" IsIndeterminate="True" Width="80" Height="6" Margin="10,0,0,0" Visibility="Collapsed" Background="#550000" Foreground="#FF2222"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- COLUMN 2: RIGHT SOCIAL FEED & LIVE CHAT -->
        <Border Grid.Column="2" Background="#121212" BorderBrush="#222222" BorderThickness="1,0,0,0">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Header -->
                    <RowDefinition Height="*" />    <!-- Social/Comment list -->
                    <RowDefinition Height="Auto" /> <!-- Milestones & Stats Summary -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="FEED SOCIAL AO VIVO" FontSize="16" FontWeight="Bold" Foreground="#FF2222" />
                    <TextBlock Text="Reações dos fãs e atividades sociais em tempo real." FontSize="10" Foreground="#666666" Margin="0,2,0,0"/>
                    <Separator Background="#222222" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Scrollable Social Comment Stream -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="socialFeedContainer">
                        <!-- Dynamic fan chat bubble blocks added in code-behind -->
                        <Border Background="#181818" CornerRadius="8" Padding="10" Margin="0,0,0,10" BorderBrush="#262626" BorderThickness="1">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="👤 YoutuberGamer:" FontSize="11" FontWeight="Bold" Foreground="#FF2222" Margin="0,0,5,0"/>
                                    <TextBlock Grid.Column="1" Text="30 segundos atrás" FontSize="9" Foreground="#555555" HorizontalAlignment="Right"/>
                                </Grid>
                                <TextBlock Text="Mal posso esperar para ver os primeiros vídeos desse canal! Sucesso! 🚀" FontSize="11" Foreground="#DDDDDD" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#181818" CornerRadius="8" Padding="10" Margin="0,0,0,10" BorderBrush="#262626" BorderThickness="1">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="👤 SpeedRunner99:" FontSize="11" FontWeight="Bold" Foreground="#FF2222" Margin="0,0,5,0"/>
                                    <TextBlock Grid.Column="1" Text="1 minuto atrás" FontSize="9" Foreground="#555555" HorizontalAlignment="Right"/>
                                </Grid>
                                <TextBlock Text="Será que teremos gameplays profissionais por aqui? Me inscrevi! 🎮" FontSize="11" Foreground="#DDDDDD" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Channel Statistics Summary -->
                <Border Grid.Row="2" Background="#181818" CornerRadius="8" Padding="12" BorderBrush="#262626" BorderThickness="1" Margin="0,15,0,0">
                    <StackPanel>
                        <TextBlock Text="SUMÁRIO DO DIA" FontSize="12" FontWeight="Bold" Foreground="#AAAAAA" Margin="0,0,0,6"/>
                        
                        <!-- Canal Selector Combo -->
                        <ComboBox x:Name="cbActiveChannelFilter" Height="26" Margin="0,0,0,10" Background="#262626" Foreground="White" SelectionChanged="cbActiveChannelFilter_SelectionChanged">
                            <!-- Items populated dynamically in code-behind -->
                        </ComboBox>
                        
                        <Grid Margin="0,2">
                            <TextBlock Text="Total de Inscritos:" FontSize="11" Foreground="#888888"/>
                            <TextBlock x:Name="txtTotalSubscribers" Text="0" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,2">
                            <TextBlock Text="Total de Vídeos:" FontSize="11" Foreground="#888888"/>
                            <TextBlock x:Name="txtTotalVideos" Text="0" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <Grid Margin="0,2">
                            <TextBlock Text="Visualizações Totais:" FontSize="11" Foreground="#888888"/>
                            <TextBlock x:Name="txtTotalViews" Text="0" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,2">
                            <TextBlock Text="Custo de Vida Diário:" FontSize="11" Foreground="#888888"/>
                            <TextBlock x:Name="txtCostOfLiving" Text="$50.00" FontSize="11" FontWeight="Bold" Foreground="#FF5555" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>