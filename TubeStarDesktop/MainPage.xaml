<UserControl x:Class="TubeStar.MainPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:TubeStar"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Custom.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="LayoutRoot" Background="#080808">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="colRight" Width="300" />
        </Grid.ColumnDefinitions>

        <!-- COLUMN 0: LEFT SIDEBAR NAVIGATION -->
        <Border Grid.Column="0" Background="#121212" BorderBrush="#222222" BorderThickness="0,0,1,0">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Logo/Header -->
                    <RowDefinition Height="*" />    <!-- Nav Menu -->
                    <RowDefinition Height="Auto" /> <!-- System Controls -->
                    <RowDefinition Height="Auto" /> <!-- Profile Card -->
                </Grid.RowDefinitions>

                <!-- Header Logo -->
                <StackPanel Grid.Row="0" Margin="0,0,0,25">
                    <TextBlock Text="TUBE STAR" FontSize="26" FontWeight="Black" Foreground="#FF2222" HorizontalAlignment="Center"/>
                    <TextBlock Text="GAMER DASHBOARD" FontSize="10" Foreground="#666666" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Grid.Row="1" Orientation="Vertical">
                    <ToggleButton x:Name="btnDailyPlanner" IsChecked="True" Height="42" Margin="0,4" HorizontalContentAlignment="Left" Padding="12,0" Click="btnDailyPlanner_Click">
                        <ToggleButton.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/Home_icon.png" Width="16" Height="16" Margin="0,0,10,0" />
                                <TextBlock x:Name="txtDailyPlanner" Text="Agenda Diária" VerticalAlignment="Center" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                        </ToggleButton.Content>
                    </ToggleButton>

                    <ToggleButton x:Name="btnVideoPlanner" Height="42" Margin="0,4" HorizontalContentAlignment="Left" Padding="12,0" Click="btnVideoPlanner_Click">
                        <ToggleButton.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/Video_icon.png" Width="16" Height="16" Margin="0,0,10,0" />
                                <TextBlock x:Name="txtVideoPlanner" Text="Meus Vídeos" VerticalAlignment="Center" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                        </ToggleButton.Content>
                    </ToggleButton>

                    <ToggleButton x:Name="btnOnlineStore" Height="42" Margin="0,4" HorizontalContentAlignment="Left" Padding="12,0" Click="btnOnlineStore_Click">
                        <ToggleButton.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/Cart_icon.png" Width="16" Height="16" Margin="0,0,10,0" />
                                <TextBlock x:Name="txtOnlineStore" Text="Loja de Equipamentos" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" />
                            </StackPanel>
                        </ToggleButton.Content>
                    </ToggleButton>

                    <ToggleButton x:Name="btnRivals" Height="42" Margin="0,4" HorizontalContentAlignment="Left" Padding="12,0" Click="btnRivals_Click">
                        <ToggleButton.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/Rivals_icon.png" Width="16" Height="16" Margin="0,0,10,0" />
                                <TextBlock x:Name="txtRivals" Text="Canais Rivais" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" />
                            </StackPanel>
                        </ToggleButton.Content>
                    </ToggleButton>

                     <ToggleButton x:Name="btnStockMarket" Height="42" Margin="0,4" HorizontalContentAlignment="Left" Padding="12,0" Click="btnStockMarket_Click">
                         <ToggleButton.Content>
                             <StackPanel Orientation="Horizontal">
                                 <Image Source="/Resources/commons.png" Width="16" Height="16" Margin="0,0,10,0" />
                                 <TextBlock x:Name="txtStockMarket" Text="Bolsa de Valores" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" />
                             </StackPanel>
                         </ToggleButton.Content>
                     </ToggleButton>

                     <ToggleButton x:Name="btnCareer" Height="42" Margin="0,4" HorizontalContentAlignment="Left" Padding="12,0" Click="btnCareer_Click">
                         <ToggleButton.Content>
                             <StackPanel Orientation="Horizontal">
                                 <Image Source="/Resources/Rivals_icon.png" Width="16" Height="16" Margin="0,0,10,0" />
                                 <TextBlock x:Name="txtCareer" Text="Carreira &amp; Empregos" VerticalAlignment="Center" FontSize="13" FontWeight="Bold"/>
                             </StackPanel>
                         </ToggleButton.Content>
                     </ToggleButton>
                     <ToggleButton x:Name="btnGovernment" Height="42" Margin="0,4" HorizontalContentAlignment="Left" Padding="12,0" Click="btnGovernment_Click">
                         <ToggleButton.Content>
                             <StackPanel Orientation="Horizontal">
                                 <Image Source="/Resources/StoreItems/Lawyer.jpg" Width="16" Height="16" Margin="0,0,10,0" />
                                 <TextBlock x:Name="txtGovernment" Text="Portal do Governo" VerticalAlignment="Center" FontSize="13" FontWeight="Bold"/>
                             </StackPanel>
                         </ToggleButton.Content>
                     </ToggleButton>
                 </StackPanel>

                <!-- System Controls (Save/Help/Exit) -->
                <Border Grid.Row="2" Background="#181818" CornerRadius="6" Padding="8" Margin="0,0,0,15" BorderBrush="#222222" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" x:Name="imgSave" Source="Resources/Disk.png" Height="24" Width="24" MouseLeftButtonDown="Save_MouseLeftButtonDown" Style="{StaticResource TriggerClickStyle}" MouseEnter="imgSave_MouseEnter" MouseLeave="imgSave_MouseLeave" Cursor="Hand"/>
                        <Image Grid.Column="1" x:Name="gridHelp" Source="Resources/Help.png" Height="24" Width="24" MouseLeftButtonDown="Tutorial_MouseLeftButtonDown" Style="{StaticResource TriggerClickStyle}" MouseEnter="gridHelp_MouseEnter" MouseLeave="gridHelp_MouseLeave" Cursor="Hand"/>
                        <Image Grid.Column="2" x:Name="gridExit" Source="Resources/Exit.png" Height="24" Width="24" MouseLeftButtonDown="Exit_MouseLeftButtonDown" Style="{StaticResource TriggerClickStyle}" MouseEnter="gridExit_MouseEnter" MouseLeave="gridExit_MouseLeave" Cursor="Hand"/>
                    </Grid>
                </Border>

                <!-- Youtuber Character Profile Card -->
                <Border Grid.Row="3" Background="#1E1E1E" CornerRadius="10" BorderBrush="#333333" BorderThickness="1" Padding="10" Cursor="Hand" MouseLeftButtonDown="ProfileCard_Click" ToolTip="Clique para customizar seu visual!">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Mini circular glowing avatar representing neon hair color -->
                        <Border Grid.Column="0" x:Name="profileAvatarGlow" Width="50" Height="50" CornerRadius="25" BorderThickness="2" BorderBrush="#00FFFF" Margin="0,0,10,0">
                            <Border.Effect>
                                <DropShadowEffect x:Name="profileAvatarGlowEffect" BlurRadius="8" ShadowDepth="0" Color="#00FFFF" Opacity="0.7"/>
                            </Border.Effect>
                            <Border CornerRadius="25" Background="#282828" ClipToBounds="True">
                                <Image x:Name="imgProfileAvatarMini" Stretch="UniformToFill" Margin="-4" Width="52" Height="52" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="txtProfileName" Text="Gamer Pro" FontSize="13" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="txtMoney" Text="$950.00" FontSize="12" FontWeight="Bold" Foreground="#00FF00" Margin="0,2,0,0"/>
                            <TextBlock x:Name="txtCareerDays" Text="Dia 1" FontSize="10" Foreground="#888888"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- COLUMN 1: CENTER ACTIVE WORKSPACE -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />    <!-- Content Panel -->
                <RowDefinition Height="Auto" /> <!-- Next Day Action Bar -->
            </Grid.RowDefinitions>

            <!-- Dashboard Content Container (Premium Card View) -->
            <Border Grid.Row="0" Background="#121212" CornerRadius="12" BorderBrush="#2E2E2E" BorderThickness="1" Padding="15">
                <Grid>
                    <!-- Active Views -->
                    <local:DailyPlanner x:Name="dailyPlanner" />
                    <local:VideoManagerControl x:Name="videoManager" Visibility="Collapsed" />
                    <local:OnlineStoreControl x:Name="onlineStore" Visibility="Collapsed" />
                    <local:RivalControl x:Name="rivalViewer" Visibility="Collapsed" />
                    <local:StockMarketControl x:Name="stockMarket" Visibility="Collapsed" />

                    <local:CareerControl x:Name="careerControl" Visibility="Collapsed" />
                    <local:GovernmentControl x:Name="governmentControl" Visibility="Collapsed" />
                </Grid>
            </Border>

            <!-- Next Day Action Bar at the Bottom -->
            <Border Grid.Row="1" Background="#121212" CornerRadius="10" BorderBrush="#2E2E2E" BorderThickness="1" Padding="12" Margin="0,15,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtNewDay" Text="Iniciar Dia 2!" FontSize="15" FontWeight="Bold" Foreground="#FF2222" />
                        <TextBlock Text="Planeje suas tarefas diárias na agenda antes de passar o dia." FontSize="11" Foreground="#888888" Margin="0,2,0,0" />
                    </StackPanel>

                    <!-- Next Day glowing button -->
                    <Button Grid.Column="1" x:Name="btnNewDay" Height="45" Width="220" FontSize="16" Click="btnNewDay_Click" Style="{StaticResource TriggerClickStyle}" Background="#FF2222" Foreground="White" BorderThickness="0">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/Play_icon.png" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="PASSAR O DIA" FontWeight="Bold" VerticalAlignment="Center"/>
                                <ProgressBar x:Name="progress" IsIndeterminate="True" Width="80" Height="6" Margin="10,0,0,0" Visibility="Collapsed" Background="#550000" Foreground="#FF2222"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- COLUMN 2: RIGHT SOCIAL FEED & LIVE CHAT (YOUTUBER'S SMARTPHONE) -->
        <Border x:Name="borderRight" Grid.Column="2" Background="#0C0C0C" BorderBrush="#222222" BorderThickness="1,0,0,0" Padding="10,15">
            <Border Background="#121212" BorderBrush="#2E2E2E" BorderThickness="4" CornerRadius="28" Padding="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#000000" Opacity="0.6"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Phone Status Bar -->
                        <RowDefinition Height="*" />    <!-- Active App Content Panel -->
                        <RowDefinition Height="Auto" /> <!-- App Navigation Dock -->
                        <RowDefinition Height="Auto" /> <!-- Phone Home Bar -->
                    </Grid.RowDefinitions>

                    <!-- 1. Phone Status Bar -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock x:Name="txtPhoneTime" Text="09:41" FontSize="10" FontWeight="Bold" Foreground="#888888" HorizontalAlignment="Left" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        
                        <!-- Dynamic Island Notch -->
                        <Border HorizontalAlignment="Center" Width="90" Height="16" CornerRadius="8" Background="Black" VerticalAlignment="Center">
                            <TextBlock Text="InstaFans" FontSize="8" FontWeight="Bold" Foreground="#555555" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                        </Border>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0" VerticalAlignment="Center">
                            <TextBlock Text="5G" FontSize="10" FontWeight="Bold" Foreground="#888888" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="📶" FontSize="10" Foreground="#888888" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtPhoneBattery" Text="🔋 100%" FontSize="10" FontWeight="Bold" Foreground="#00FF00" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- 2. Active App Content Panel -->
                    <Grid Grid.Row="1">
                        
                        <!-- APP A: TUBEANALYZER -->
                        <Grid x:Name="appAnalyzer" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- App Title -->
                                <RowDefinition Height="*"/>    <!-- Stats Card & Feed -->
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="📊 TubeAnalyzer" FontSize="15" FontWeight="Bold" Foreground="#FF2222" />
                                <TextBlock Text="Métricas do seu canal no Youtube" FontSize="9" Foreground="#666666" Margin="0,1,0,0"/>
                                <Separator Background="#222222" Margin="0,6,0,0"/>
                            </StackPanel>
                            
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/> <!-- Chat comments -->
                                    <RowDefinition Height="Auto"/> <!-- Summary card -->
                                </Grid.RowDefinitions>
                                
                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                                    <StackPanel x:Name="socialFeedContainer">
                                        <!-- Dynamic fan comments populated in code-behind -->
                                    </StackPanel>
                                </ScrollViewer>
                                
                                <Border Grid.Row="1" Background="#181818" CornerRadius="12" Padding="12" BorderBrush="#2E2E2E" BorderThickness="1">
                                    <StackPanel>
                                        <!-- Canal Selector Combo -->
                                        <ComboBox x:Name="cbActiveChannelFilter" Height="24" Margin="0,0,0,8" Background="#262626" Foreground="White" SelectionChanged="cbActiveChannelFilter_SelectionChanged">
                                            <!-- Items populated dynamically in code-behind -->
                                        </ComboBox>
                                        
                                        <Grid Margin="0,2">
                                            <TextBlock Text="Total de Inscritos:" FontSize="11" Foreground="#888888"/>
                                            <TextBlock x:Name="txtTotalSubscribers" Text="0" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                                        </Grid>

                                        <Grid Margin="0,2">
                                            <TextBlock Text="Total de Vídeos:" FontSize="11" Foreground="#888888"/>
                                            <TextBlock x:Name="txtTotalVideos" Text="0" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                                        </Grid>
                                        
                                        <Grid Margin="0,2">
                                            <TextBlock Text="Visualizações Totais:" FontSize="11" Foreground="#888888"/>
                                            <TextBlock x:Name="txtTotalViews" Text="0" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                                        </Grid>

                                        <Grid Margin="0,2">
                                            <TextBlock Text="Custo de Vida Diário:" FontSize="11" Foreground="#888888"/>
                                            <TextBlock x:Name="txtCostOfLiving" Text="$50.00" FontSize="11" FontWeight="Bold" Foreground="#FF5555" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- APP B: INSTAFANS (Instagram replica) -->
                        <Grid x:Name="appInstaFans" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Profile Header -->
                                <RowDefinition Height="Auto"/> <!-- Post Action Button -->
                                <RowDefinition Height="*"/>    <!-- Scrollable Photo Feed -->
                            </Grid.RowDefinitions>
                            
                            <!-- Profile Header -->
                            <Border Grid.Row="0" CornerRadius="10" Margin="0,0,0,10" Padding="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1E1E1E" Offset="0"/>
                                        <GradientStop Color="#252528" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Avatar with Story gradient ring -->
                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" BorderThickness="2" Padding="1" Margin="0,0,8,0">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#833AB4" Offset="0.0"/>
                                                <GradientStop Color="#FD1D1D" Offset="0.5"/>
                                                <GradientStop Color="#FCAF45" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border CornerRadius="22" Background="#282828" ClipToBounds="True">
                                            <Image x:Name="imgInstaAvatar" Stretch="UniformToFill" Margin="-1"/>
                                        </Border>
                                    </Border>
                                    
                                    <Grid Grid.Column="1" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock x:Name="txtInstaPosts" Text="0" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            <TextBlock Text="posts" FontSize="9" Foreground="#888888" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock x:Name="txtInstaFollowers" Text="0" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            <TextBlock Text="seguidores" FontSize="9" Foreground="#888888" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                            
                            <!-- Post Button -->
                            <Button Grid.Row="1" x:Name="btnPostInsta" Content="📸 POSTAR CONTEÚDO" Height="28" Margin="0,0,0,10" Background="#E1306C" Foreground="White" FontWeight="Bold" FontSize="11" Click="btnPostInsta_Click" Style="{StaticResource TriggerClickStyle}"/>
                            
                            <!-- Photo Feed -->
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="instaPostsContainer">
                                    <!-- Dynamic photo cards go here -->
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <!-- 3. App Navigation Dock -->
                    <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="12" Padding="4" Margin="0,10,0,0" BorderBrush="#2C2C2C" BorderThickness="1">
                        <UniformGrid Columns="2">
                            <ToggleButton x:Name="btnNavAnalyzer" IsChecked="True" Content="📊 Analyzer" FontSize="11" FontWeight="Bold" Padding="6" Background="Transparent" BorderThickness="0" Foreground="White" Click="btnNavAnalyzer_Click"/>
                            <ToggleButton x:Name="btnNavInstaFans" Content="📸 InstaFans" FontSize="11" FontWeight="Bold" Padding="6" Background="Transparent" BorderThickness="0" Foreground="#888888" Click="btnNavInstaFans_Click"/>
                        </UniformGrid>
                    </Border>

                    <!-- 4. Phone Home Indicator Bar -->
                    <Border Grid.Row="3" Height="4" Width="80" Background="#444444" CornerRadius="2" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>