<UserControl x:Class="TubeStar.AssetBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             Width="380" 
             Margin="5"
             Padding="0"
             MouseEnter="UserControl_MouseEnter"
             MouseLeave="UserControl_MouseLeave">

    <Border x:Name="borderFrame" CornerRadius="8" Background="#1E1E1E" BorderBrush="#2E2E2E" BorderThickness="1" Padding="8">
        <Grid x:Name="LayoutRoot" Background="Transparent" MouseLeftButtonDown="LayoutRoot_MouseLeftButtonDown" Cursor="Hand">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Image with rounded corners -->
            <Border Grid.Column="0" CornerRadius="6" ClipToBounds="True" Background="#121212" Height="110" Width="110" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image x:Name="imgAsset" Stretch="UniformToFill"></Image>
            </Border>

            <!-- Info Panel -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Title & Price -->
                    <RowDefinition Height="*"/>    <!-- Sub-stats / Taxes -->
                    <RowDefinition Height="Auto"/> <!-- Button / Status -->
                </Grid.RowDefinitions>

                <!-- Row 0: Title and Price -->
                <Grid Grid.Row="0" Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="txtName" Grid.Column="0" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtPrice" Grid.Column="1" FontSize="14" FontWeight="Bold" Foreground="#FF5555" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <!-- Row 1: Sub-stats -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock x:Name="txtTax" FontSize="11" Foreground="#FFF5A623" Margin="0,2,0,0"/>
                    <TextBlock x:Name="txtRent" FontSize="11" Foreground="#FF2ECC71" Margin="0,2,0,0" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Row 2: Buy button / Owned status -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="btnBuy" Grid.Column="1" Width="100" Height="28" FontSize="12" FontWeight="Bold" Click="btnBuy_Click" HorizontalAlignment="Right" Content="Comprar"/>
                    <TextBlock x:Name="txtStatus" Grid.Column="1" FontSize="12" FontWeight="Bold" Foreground="#666666" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed" Text="Adquirido"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
