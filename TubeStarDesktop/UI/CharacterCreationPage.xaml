<UserControl x:Class="TubeStar.CharacterCreationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1000"
             Background="#080808">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Custom.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Next-Gen -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="CRIADOR DE PERSONAGEM" FontSize="26" FontWeight="Black" Foreground="#FF2222"/>
            <TextBlock Text="Escolha o visual do seu YouTuber e defina a sua identidade ideal de forma 100% interativa." FontSize="12" Foreground="#888888" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Main Workspace: Two-Column Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Complex RPG Customization Panels -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,15,0">
                <StackPanel Orientation="Vertical">
                    
                    <!-- CATEGORY 1: SOCIAL IDENTITY -->
                    <!-- CATEGORY 1: SOCIAL IDENTITY -->
                    <Border Background="#161616" CornerRadius="12" Padding="14" Margin="0,0,0,12" BorderBrush="#2C2C2C" BorderThickness="1.2">
                        <StackPanel>
                            <TextBlock Text="SOCIAL IDENTITY" FontSize="14" FontWeight="Black" Foreground="#FF2222" Margin="0,0,0,8"/>
                            <TextBlock Text="Nome do Personagem / YouTuber" FontSize="11" Foreground="#888888" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtYoutuberName" Text="Gamer Pro" FontSize="15" Height="36" VerticalContentAlignment="Center" Padding="8,0" Background="#1E1E1E" Foreground="White" BorderBrush="#2E2E2E" Margin="0,0,0,5" TextChanged="InputChanged"/>
                        </StackPanel>
                    </Border>

                    <!-- CATEGORY 2: AVATAR SELECTION -->
                    <Border Background="#161616" CornerRadius="12" Padding="14" Margin="0,0,0,12" BorderBrush="#2C2C2C" BorderThickness="1.2">
                        <StackPanel>
                            <TextBlock Text="SELEÇÃO DE AVATAR GAMER" FontSize="14" FontWeight="Black" Foreground="#FF2222" Margin="0,0,0,8"/>
                            
                            <!-- Abas de Categorias de Avatar -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="tabBusiness" Grid.Column="0" Content="💼 Negócios" Height="30" Margin="1" Click="Tab_Click" IsChecked="True"/>
                                <ToggleButton x:Name="tabTrap" Grid.Column="1" Content="🎤 Trap &amp; Style" Height="30" Margin="1" Click="Tab_Click"/>
                                <ToggleButton x:Name="tabCasual" Grid.Column="2" Content="👕 Casual &amp; Urbano" Height="30" Margin="1" Click="Tab_Click"/>
                            </Grid>

                            <!-- Grade de Avatares: Negócios -->
                            <UniformGrid x:Name="gridBusinessAvatars" Columns="2" Margin="0,0,0,2" Visibility="Visible">
                                <Button x:Name="btnAvatar1" Content="Empresário Jovem" Height="36" Margin="2" Click="Avatar_Click" Tag="0"/>
                                <Button x:Name="btnAvatar2" Content="Empresária Jovem" Height="36" Margin="2" Click="Avatar_Click" Tag="1"/>
                            </UniformGrid>

                            <!-- Grade de Avatares: Trap -->
                            <UniformGrid x:Name="gridTrapAvatars" Columns="2" Margin="0,0,0,2" Visibility="Collapsed">
                                <Button x:Name="btnAvatar3" Content="Trap Estilo Pink" Height="36" Margin="2" Click="Avatar_Click" Tag="2"/>
                                <Button x:Name="btnAvatar4" Content="Trap Streetwear" Height="36" Margin="2" Click="Avatar_Click" Tag="3"/>
                            </UniformGrid>

                            <!-- Grade de Avatares: Casual -->
                            <UniformGrid x:Name="gridCasualAvatars" Columns="2" Margin="0,0,0,2" Visibility="Collapsed">
                                <Button x:Name="btnAvatar5" Content="Casual Gamer Boy" Height="36" Margin="2" Click="Avatar_Click" Tag="4"/>
                                <Button x:Name="btnAvatar6" Content="Casual Indie Girl" Height="36" Margin="2" Click="Avatar_Click" Tag="5"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- CATEGORY 3: STARTING ORIGIN / PERKS -->
                    <Border Background="#161616" CornerRadius="12" Padding="14" Margin="0,0,0,12" BorderBrush="#2C2C2C" BorderThickness="1.2">
                        <StackPanel>
                            <TextBlock Text="ESCOLHA SUA ORIGEM (PERK INICIAL)" FontSize="14" FontWeight="Black" Foreground="#FF2222" Margin="0,0,0,8"/>
                            
                            <StackPanel Margin="0,2,0,5">
                                <RadioButton x:Name="rbPerkStudent" GroupName="StartingPerks" IsChecked="True" Checked="Perk_Checked">
                                    <TextBlock Text="🎬 Estudante de Cinema" FontWeight="Bold" Foreground="White"/>
                                </RadioButton>
                                <TextBlock Text="Focado em pós-produção. Começa com +20 em Edição (Total 40)." FontSize="11" Foreground="#888888" Margin="18,1,0,8"/>

                                <RadioButton x:Name="rbPerkGamer" GroupName="StartingPerks" Checked="Perk_Checked">
                                    <TextBlock Text="🎮 Gamer Hardcore" FontWeight="Bold" Foreground="White"/>
                                </RadioButton>
                                <TextBlock Text="Mestre na captação. Inicia com +20 em Gravação (Total 50)." FontSize="11" Foreground="#888888" Margin="18,1,0,8"/>

                                <RadioButton x:Name="rbPerkHeir" GroupName="StartingPerks" Checked="Perk_Checked">
                                    <TextBlock Text="💰 Herdeiro de Startup" FontWeight="Bold" Foreground="White"/>
                                </RadioButton>
                                <TextBlock Text="Suporte financeiro. Inicia com +R$ 1.500 no caixa inicial (Total R$ 2.450)." FontSize="11" Foreground="#888888" Margin="18,1,0,8"/>

                                <RadioButton x:Name="rbPerkAnalytic" GroupName="StartingPerks" Checked="Perk_Checked">
                                    <TextBlock Text="📊 Editor Analítico" FontWeight="Bold" Foreground="White"/>
                                </RadioButton>
                                <TextBlock Text="Olhar clínico. Desbloqueia permanentemente ver a qualidade do vídeo antes de publicá-lo." FontSize="11" Foreground="#888888" Margin="18,1,0,2"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Large Prominent Neon Red Button -->
                    <Grid Height="55" Margin="0,8,0,25">
                        <Border CornerRadius="8" Background="#FF2222" Opacity="0.15" Margin="-2">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#FF2222" Opacity="0.9"/>
                            </Border.Effect>
                        </Border>
                        <Button x:Name="btnStartGame" Content="INICIAR CARREIRA GAMER" FontSize="16" FontWeight="Black" Background="#FF2222" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnStartGame_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Right Column: Immersive Vector Avatar Customizer Preview -->
            <Border Grid.Column="1" CornerRadius="16" BorderThickness="1.5" Margin="12,0,0,25" Padding="18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#161618" Offset="0"/>
                        <GradientStop Color="#0D0D0E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3E3E42" Offset="0"/>
                        <GradientStop Color="#1E1E1E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
 
                    <TextBlock Grid.Row="0" Text="PREVIEW DO AVATAR EM TEMPO REAL" FontSize="12" FontWeight="Black" Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <!-- Circular Glowing Aura circular -->
                    <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10">
                        <Border x:Name="avatarGlowBorder" Width="260" Height="260" CornerRadius="130" BorderThickness="4" BorderBrush="#FF2222">
                            <Border.Effect>
                                <DropShadowEffect x:Name="glowShadow" BlurRadius="35" ShadowDepth="0" Color="#FF2222" Opacity="0.8"/>
                            </Border.Effect>
                            
                            <!-- Inner Avatar Design Area -->
                            <Grid>
                                <Border CornerRadius="126" Background="#0A0F1A" ClipToBounds="True">
                                    <Image x:Name="imgAvatarPreview" Stretch="UniformToFill" Margin="-22" Width="264" Height="264" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Customization Summary Info Card -->
                    <Border Grid.Row="2" Background="#181818" CornerRadius="8" Padding="12" BorderBrush="#2A2A2A" BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="txtSummaryChannel" Text="YOUTUBER: Gamer Pro" FontSize="14" FontWeight="Black" Foreground="#FF2222" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <Separator Background="#2A2A2A" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="txtSummaryOutfit" Text="👕 Estilo: -" FontSize="11" Foreground="#CCCCCC" Margin="0,2" FontWeight="Bold"/>
                                    <TextBlock x:Name="txtSummaryTattoo" Text="💉 Detalhes: -" FontSize="11" Foreground="#CCCCCC" Margin="0,2" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="txtSummaryAccessory" Text="💍 Acessórios: -" FontSize="11" Foreground="#CCCCCC" Margin="0,2" FontWeight="Bold"/>
                                    <TextBlock x:Name="txtSummaryHair" Text="⚡ Perfil: -" FontSize="11" Foreground="#CCCCCC" Margin="0,2" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>

                            <Separator Background="#2A2A2A" Margin="0,0,0,8"/>
                            
                            <!-- Atributos Iniciais -->
                            <TextBlock Text="VANTAGENS INICIAIS DA ORIGEM" FontSize="11" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                            <Grid SnapsToDevicePixels="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="txtSummaryMoney" Text="💵 Dinheiro: R$ 950" FontSize="11" Foreground="#FF2ECC71" Margin="0,1" FontWeight="Bold"/>
                                    <TextBlock x:Name="txtSummaryShooting" Text="🎥 Gravação: 30" FontSize="11" Foreground="#CCCCCC" Margin="0,1" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="txtSummaryEditing" Text="✂️ Edição: 20" FontSize="11" Foreground="#CCCCCC" Margin="0,1" FontWeight="Bold"/>
                                    <TextBlock x:Name="txtSummarySpecial" Text="🔍 Analítico: Não" FontSize="11" Foreground="#CCCCCC" Margin="0,1" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
