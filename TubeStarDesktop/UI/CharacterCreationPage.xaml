<UserControl x:Class="TubeStar.CharacterCreationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1000"
             Background="#080808">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Custom.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Next-Gen -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="CRIADOR DE PERSONAGEM" FontSize="26" FontWeight="Black" Foreground="#FF2222"/>
            <TextBlock Text="Escolha o visual do seu YouTuber e defina a sua identidade ideal de forma 100% interativa." FontSize="12" Foreground="#888888" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Main Workspace: Two-Column Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Complex RPG Customization Panels -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,15,0">
                <StackPanel Orientation="Vertical">
                    
                    <!-- CATEGORY 1: SOCIAL IDENTITY -->
                    <Border Background="#121212" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#222222" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="SOCIAL IDENTITY" FontSize="14" FontWeight="Black" Foreground="#FF2222" Margin="0,0,0,8"/>
                            <TextBlock Text="Nome do Personagem / YouTuber" FontSize="11" Foreground="#888888" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtYoutuberName" Text="Gamer Pro" FontSize="15" Height="36" VerticalContentAlignment="Center" Padding="8,0" Background="#1E1E1E" Foreground="White" BorderBrush="#2E2E2E" Margin="0,0,0,5" TextChanged="InputChanged"/>
                        </StackPanel>
                    </Border>

                    <!-- CATEGORY 2: AVATAR SELECTION -->
                    <Border Background="#121212" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#222222" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="SELEÇÃO DE AVATAR GAMER (ESTILO AAA)" FontSize="14" FontWeight="Black" Foreground="#FF2222" Margin="0,0,0,8"/>
                            
                            <!-- Grupo 1: Empresários & Mauricinhos -->
                            <TextBlock Text="💼 EMPRESÁRIOS &amp; MAURICINHOS" FontSize="11" FontWeight="Bold" Foreground="#888888" Margin="0,5,0,5"/>
                            <UniformGrid Columns="2" Margin="0,0,0,8">
                                <Button x:Name="btnAvatar1" Content="Mauricinho Executivo" Height="36" Margin="2" Click="Avatar_Click" Tag="0"/>
                                <Button x:Name="btnAvatar2" Content="Mauricinho Casual" Height="36" Margin="2" Click="Avatar_Click" Tag="1"/>
                                <Button x:Name="btnAvatar3" Content="Empresário Jovem" Height="36" Margin="2" Click="Avatar_Click" Tag="2"/>
                                <Button x:Name="btnAvatar4" Content="Empresário Maduro" Height="36" Margin="2" Click="Avatar_Click" Tag="3"/>
                            </UniformGrid>

                            <!-- Grupo 2: Estilo Trap -->
                            <TextBlock Text="🎤 ESTILO TRAP &amp; GANGSTAR" FontSize="11" FontWeight="Bold" Foreground="#888888" Margin="0,5,0,5"/>
                            <UniformGrid Columns="3" Margin="0,0,0,8">
                                <Button x:Name="btnAvatar5" Content="Trap Messy Pink" Height="36" Margin="2" Click="Avatar_Click" Tag="4"/>
                                <Button x:Name="btnAvatar6" Content="Trap Hip-Hop" Height="36" Margin="2" Click="Avatar_Click" Tag="5"/>
                                <Button x:Name="btnAvatar11" Content="Trap Platinado" Height="36" Margin="2" Click="Avatar_Click" Tag="10"/>
                            </UniformGrid>

                            <!-- Grupo 3: Estilo Casual -->
                            <TextBlock Text="👕 ESTILO CASUAL &amp; URBANO" FontSize="11" FontWeight="Bold" Foreground="#888888" Margin="0,5,0,5"/>
                            <UniformGrid Columns="2" Margin="0,0,0,2">
                                <Button x:Name="btnAvatar7" Content="Casual E-boy" Height="36" Margin="2" Click="Avatar_Click" Tag="6"/>
                                <Button x:Name="btnAvatar8" Content="Casual Rocker" Height="36" Margin="2" Click="Avatar_Click" Tag="7"/>
                                <Button x:Name="btnAvatar9" Content="Casual Cyberpunk" Height="36" Margin="2" Click="Avatar_Click" Tag="8"/>
                                <Button x:Name="btnAvatar10" Content="Casual Contemporâneo" Height="36" Margin="2" Click="Avatar_Click" Tag="9"/>
                                <Button x:Name="btnAvatar12" Content="Casual Cachos" Height="36" Margin="2" Click="Avatar_Click" Tag="11"/>
                                <Button x:Name="btnAvatar13" Content="Casual Bigode" Height="36" Margin="2" Click="Avatar_Click" Tag="12"/>
                                <Button x:Name="btnAvatar14" Content="Casual Óculos" Height="36" Margin="2" Click="Avatar_Click" Tag="13"/>
                                <Button x:Name="btnAvatar15" Content="Casual Jaqueta Couro" Height="36" Margin="2" Click="Avatar_Click" Tag="14"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Large Prominent Neon Red Button -->
                    <Grid Height="55" Margin="0,8,0,25">
                        <Border CornerRadius="6" Background="#FF2222" Opacity="0.15" Margin="-2">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#FF2222" Opacity="0.9"/>
                            </Border.Effect>
                        </Border>
                        <Button x:Name="btnStartGame" Content="INICIAR CARREIRA GAMER" FontSize="16" FontWeight="Black" Background="#FF2222" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnStartGame_Click"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Right Column: Immersive Vector Avatar Customizer Preview -->
            <Border Grid.Column="1" Background="#121212" CornerRadius="12" BorderBrush="#2E2E2E" BorderThickness="1.5" Margin="8,0,0,25" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
 
                    <TextBlock Grid.Row="0" Text="PREVIEW DO AVATAR EM TEMPO REAL" FontSize="12" FontWeight="Black" Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <!-- Circular Glowing Aura circular -->
                    <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10">
                        <Border x:Name="avatarGlowBorder" Width="260" Height="260" CornerRadius="130" BorderThickness="4" BorderBrush="#FF2222">
                            <Border.Effect>
                                <DropShadowEffect x:Name="glowShadow" BlurRadius="35" ShadowDepth="0" Color="#FF2222" Opacity="0.8"/>
                            </Border.Effect>
                            
                            <!-- Inner Avatar Design Area -->
                            <Grid>
                                <Border CornerRadius="126" Background="#0A0F1A" ClipToBounds="True">
                                    <Image x:Name="imgAvatarPreview" Stretch="UniformToFill" Margin="-22" Width="264" Height="264" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Customization Summary Info Card -->
                    <Border Grid.Row="2" Background="#181818" CornerRadius="8" Padding="12" BorderBrush="#2A2A2A" BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="txtSummaryChannel" Text="YOUTUBER: Gamer Pro" FontSize="14" FontWeight="Black" Foreground="#FF2222" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <Separator Background="#2A2A2A" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="txtSummaryOutfit" Text="👕 Estilo: -" FontSize="11" Foreground="#CCCCCC" Margin="0,2" FontWeight="Bold"/>
                                    <TextBlock x:Name="txtSummaryTattoo" Text="💉 Detalhes: -" FontSize="11" Foreground="#CCCCCC" Margin="0,2" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="txtSummaryAccessory" Text="💍 Acessórios: -" FontSize="11" Foreground="#CCCCCC" Margin="0,2" FontWeight="Bold"/>
                                    <TextBlock x:Name="txtSummaryHair" Text="⚡ Perfil: -" FontSize="11" Foreground="#CCCCCC" Margin="0,2" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
