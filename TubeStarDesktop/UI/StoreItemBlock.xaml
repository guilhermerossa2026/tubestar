<UserControl x:Class="TubeStar.StoreItemBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             Width="450" 
             Margin="2"
             Padding="2"
             MouseEnter="UserControl_MouseEnter"
             MouseLeave="UserControl_MouseLeave">

    <Border x:Name="borderFrame" CornerRadius="8" Background="#1E1E1E" BorderBrush="#2E2E2E" BorderThickness="1" Padding="5">
        <Grid x:Name="LayoutRoot" Background="Transparent" MouseLeftButtonDown="LayoutRoot_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image x:Name="imgItem" Height="150" Width="150" Margin="5" Stretch="UniformToFill"></Image>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="txtName" Grid.Column="0" FontSize="20" Text="" FontWeight="Bold" TextWrapping="Wrap" Foreground="White"></TextBlock>
                    <TextBlock x:Name="txtPrice" Width="100" Grid.Column="1" FontSize="18" HorizontalAlignment="Right" VerticalAlignment="Center" Text="" FontWeight="Bold" Foreground="#FF5555"></TextBlock>
                </Grid>
                <TextBlock x:Name="txtDescription" FontSize="16" Text="" FontStyle="Oblique" TextWrapping="Wrap" Foreground="#AAAAAA"></TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
