<xctk:ChildWindow x:Class="TubeStar.UniversitySelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Caption="Matrícula Universitária"
        WindowStartupLocation="Center"
        Width="750" Height="500">
    
    <Grid x:Name="LayoutRoot" Background="#121212">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="15,15,15,10">
            <TextBlock Text="ECOSSISTEMA DE ESTUDOS: SELECIONE SUA UNIVERSIDADE" FontSize="18" FontWeight="Bold" Foreground="#FFD700" HorizontalAlignment="Center"/>
            <TextBlock Text="Para poder estudar, você precisa se matricular em uma faculdade. A taxa de matrícula é paga uma única vez no momento do ingresso, e o custo de mensalidade será debitado diariamente. Se ficar sem dinheiro, você será jubilado!" 
                       FontSize="12" Foreground="#A0A0A0" TextWrapping="Wrap" TextAlignment="Center" Margin="0,5,0,5"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                <TextBlock Text="Seu Saldo Atual: " FontSize="14" Foreground="#FFFFFF"/>
                <TextBlock x:Name="txtCurrentBalance" Text="$0,00" FontSize="14" FontWeight="Bold" Foreground="#00FF00"/>
            </StackPanel>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="4" Margin="10,5,10,15">
            <!-- EAD Cruzeiro do Sul -->
            <Border Background="#1E1E1E" BorderBrush="#2E2E2E" BorderThickness="2" CornerRadius="8" Margin="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="EAD" FontSize="11" FontWeight="Bold" Foreground="#00FFCC" HorizontalAlignment="Center"/>
                        <TextBlock Text="Cruzeiro do Sul" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,5"/>
                        <Separator Background="#2E2E2E" Margin="0,2,0,8"/>
                    </StackPanel>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TextBlock FontSize="12" Foreground="#CCCCCC" TextWrapping="Wrap" LineHeight="18">
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Matrícula:</Run> $5.000<LineBreak/>
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Mensalidade:</Run> $15/dia<LineBreak/>
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Velocidade:</Run> Normal (1.0x)<LineBreak/>
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Restrição:</Run> Estuda apenas até nível II (Gravação II, Edição II, Análise I).<LineBreak/>
                            • Não dá acesso a detalhamento de scores dos vídeos.
                        </TextBlock>
                    </ScrollViewer>
                    
                    <Button Grid.Row="2" x:Name="btnEnrollEAD" Content="Matricular-se ($5.000)" Height="35" Click="EnrollEAD_Click" Margin="0,8,0,0" Background="#252525" Foreground="#FFFFFF" FontWeight="Bold" BorderBrush="#00FFCC"/>
                </Grid>
            </Border>

            <!-- PUC-Rio -->
            <Border Background="#1E1E1E" BorderBrush="#2E2E2E" BorderThickness="2" CornerRadius="8" Margin="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="PRESENCIAL" FontSize="11" FontWeight="Bold" Foreground="#FFA500" HorizontalAlignment="Center"/>
                        <TextBlock Text="PUC-Rio" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,5"/>
                        <Separator Background="#2E2E2E" Margin="0,2,0,8"/>
                    </StackPanel>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TextBlock FontSize="12" Foreground="#CCCCCC" TextWrapping="Wrap" LineHeight="18">
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Matrícula:</Run> $10.000<LineBreak/>
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Mensalidade:</Run> $75/dia<LineBreak/>
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Velocidade:</Run> +20% (1.2x)<LineBreak/>
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Estudos:</Run> Libera todos os cursos, incluindo nível III.<LineBreak/>
                            • Excelente reputação acadêmica e networking.
                        </TextBlock>
                    </ScrollViewer>
                    
                    <Button Grid.Row="2" x:Name="btnEnrollPUC" Content="Matricular-se ($10.000)" Height="35" Click="EnrollPUC_Click" Margin="0,8,0,0" Background="#252525" Foreground="#FFFFFF" FontWeight="Bold" BorderBrush="#FFA500"/>
                </Grid>
            </Border>

            <!-- MIT / Insper -->
            <Border Background="#1E1E1E" BorderBrush="#2E2E2E" BorderThickness="2" CornerRadius="8" Margin="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="ELITE MUNDIAL" FontSize="11" FontWeight="Bold" Foreground="#FF3366" HorizontalAlignment="Center"/>
                        <TextBlock Text="MIT / Insper" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,5"/>
                        <Separator Background="#2E2E2E" Margin="0,2,0,8"/>
                    </StackPanel>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TextBlock FontSize="12" Foreground="#CCCCCC" TextWrapping="Wrap" LineHeight="18">
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Matrícula:</Run> $20.000<LineBreak/>
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Mensalidade:</Run> $250/dia<LineBreak/>
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Velocidade:</Run> +40% (1.4x)<LineBreak/>
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Habilidades:</Run> Ganho em dobro (2.0x)!<LineBreak/>
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Recurso Premium:</Run> Revela breakdown de score de qualidade dos vídeos ao graduar em Análise de Qualidade.
                        </TextBlock>
                    </ScrollViewer>
                    
                    <Button Grid.Row="2" x:Name="btnEnrollMIT" Content="Matricular-se ($20.000)" Height="35" Click="EnrollMIT_Click" Margin="0,8,0,0" Background="#252525" Foreground="#FFFFFF" FontWeight="Bold" BorderBrush="#FF3366"/>
                </Grid>
            </Border>
            
            <!-- Faculdade de IA -->
            <Border Background="#1E1E1E" BorderBrush="#2E2E2E" BorderThickness="2" CornerRadius="8" Margin="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="AUTOMAÇÃO &amp; SEO" FontSize="11" FontWeight="Bold" Foreground="#8B5CF6" HorizontalAlignment="Center"/>
                        <TextBlock Text="Faculdade de IA" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,5"/>
                        <Separator Background="#2E2E2E" Margin="0,2,0,8"/>
                    </StackPanel>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TextBlock FontSize="12" Foreground="#CCCCCC" TextWrapping="Wrap" LineHeight="18">
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Matrícula:</Run> $12.000<LineBreak/>
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Mensalidade:</Run> $90/dia<LineBreak/>
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Velocidade:</Run> +10% (1.1x)<LineBreak/>
                            • <Run FontWeight="Bold" Foreground="#FFFFFF">Benefício Exclusivo:</Run> Formar-se em qualquer curso destrava a automação de títulos e otimização por IA, concedendo +5% de CTR permanente em todos os vídeos.
                        </TextBlock>
                    </ScrollViewer>
                    
                    <Button Grid.Row="2" x:Name="btnEnrollIA" Content="Matricular-se ($12.000)" Height="35" Click="EnrollIA_Click" Margin="0,8,0,0" Background="#252525" Foreground="#FFFFFF" FontWeight="Bold" BorderBrush="#8B5CF6"/>
                </Grid>
            </Border>
        </UniformGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="15,0,15,15">
            <Button x:Name="btnCancel" IsCancel="True" MinWidth="100" Height="30" Content="Cancelar" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</xctk:ChildWindow>
