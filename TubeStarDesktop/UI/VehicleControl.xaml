<UserControl x:Class="TubeStar.VehicleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TubeStar"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="800"
             Background="#121212">

    <Grid x:Name="LayoutRoot" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Tabs -->
            <RowDefinition Height="*" />    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Row 0: Header with Title and Player Cash Balance -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="MERCADO DE VEÍCULOS" FontSize="20" FontWeight="Black" Foreground="#FF2222" />
                <TextBlock Text="Adquira carros, aviões, lanchas ou jetskis" FontSize="11" Foreground="#666666" FontWeight="Bold" Margin="0,2,0,0"/>
            </StackPanel>

            <Border Grid.Column="1" Background="#1E1E1E" BorderBrush="#2E2E2E" BorderThickness="1" CornerRadius="6" Padding="12,6" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="SALDO: " FontSize="14" FontWeight="Bold" Foreground="#666666" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtMoneyBalance" Text="$0.00" FontSize="16" FontWeight="Black" Foreground="#FF2ECC71" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 1: Navigation Tabs (Carros, Aviões, Lanchas, Jetskis) -->
        <Border Grid.Row="1" Background="#181818" BorderBrush="#222222" BorderThickness="1" CornerRadius="6" Padding="5" Margin="0,0,0,15">
            <UniformGrid x:Name="tabGrid" Columns="6">
                <ToggleButton x:Name="tabAll" Content="Todos" Margin="2" IsChecked="True" Click="Tab_Click"/>
                <ToggleButton x:Name="tabCar" Content="Carros" Margin="2" Click="Tab_Click"/>
                <ToggleButton x:Name="tabPlane" Content="Aviões" Margin="2" Click="Tab_Click"/>
                <ToggleButton x:Name="tabBoat" Content="Lanchas" Margin="2" Click="Tab_Click"/>
                <ToggleButton x:Name="tabJetski" Content="Jetskis" Margin="2" Click="Tab_Click"/>
                <ToggleButton x:Name="tabOwned" Content="Adquiridos" Margin="2" Click="Tab_Click"/>
            </UniformGrid>
        </Border>

        <!-- Row 2: Vehicle Grid -->
        <ScrollViewer Grid.Row="2" BorderThickness="0" VerticalScrollBarVisibility="Auto">
            <UniformGrid x:Name="itemPanel" Columns="2" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        </ScrollViewer>
    </Grid>
</UserControl>
